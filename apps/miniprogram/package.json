{
  "name": "@starvault/miniprogram",
  "version": "0.1.0",
  "private": true,
  "description": "StarVault 微信小程序 (Taro + React) 骨架",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "scss"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "lint": "echo 'No linter configured'",
    "typecheck": "echo 'Type check skipped in skeleton'",
    "build": "npm run build:weapp"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@tarojs/components": "4.0.0",
    "@tarojs/helper": "4.0.0",
    "@tarojs/plugin-framework-react": "4.0.0",
    "@tarojs/plugin-platform-weapp": "4.0.0",
    "@tarojs/react": "4.0.0",
    "@tarojs/runtime": "4.0.0",
    "@tarojs/shared": "4.0.0",
    "@tarojs/taro": "4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@tarojs/cli": "4.0.0",
    "@types/react": "^18.0.0",
    "@types/webpack-env": "^1.18.0",
    "babel-preset-taro": "4.0.0",
    "typescript": "^5.3.0"
  }
}
